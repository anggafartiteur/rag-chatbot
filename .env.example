# =============================================
# RAG Chatbot - Konfigurasi Environment
# =============================================
# Dokumentasi Neuron AI: https://docs.neuron-ai.dev

# ─────────────────────────────────────────────
# LLM PROVIDER
# Pilih salah satu: anthropic | openai | gemini | mistral | deepseek | xai | ollama | cohere
# ─────────────────────────────────────────────
LLM_PROVIDER=anthropic

# ─────────────────────────────────────────────
# ANTHROPIC (https://console.anthropic.com)
# Model: claude-haiku-4-5-20251001 | claude-sonnet-4-5 | claude-opus-4-5
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─────────────────────────────────────────────
# OPENAI (https://platform.openai.com)
# Model: gpt-4o-mini | gpt-4o | gpt-4-turbo
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxx
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# GEMINI (https://aistudio.google.com)
# Model: gemini-2.0-flash | gemini-1.5-pro | gemini-1.5-flash
# ─────────────────────────────────────────────
GEMINI_API_KEY=AIzaxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────
# MISTRAL (https://console.mistral.ai)
# Model: mistral-small-latest | mistral-medium-latest | mistral-large-latest
# ─────────────────────────────────────────────
MISTRAL_API_KEY=xxxxxx
MISTRAL_MODEL=mistral-small-latest

# ─────────────────────────────────────────────
# DEEPSEEK (https://platform.deepseek.com)
# Model: deepseek-chat | deepseek-reasoner
# ─────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxx
DEEPSEEK_MODEL=deepseek-chat

# ─────────────────────────────────────────────
# XAI / GROK (https://console.x.ai)
# Model: grok-3 | grok-3-mini | grok-2
# ─────────────────────────────────────────────
XAI_API_KEY=xai-xxxxxx
XAI_MODEL=grok-3-mini

# ─────────────────────────────────────────────
# OLLAMA — LLM lokal, gratis, tidak perlu API key
# Install: https://ollama.com | jalankan: ollama serve
# Model: llama3.2 | mistral | qwen2.5 | phi3 (sesuai yang sudah di-pull)
# ─────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─────────────────────────────────────────────
# COHERE (https://dashboard.cohere.com)
# Model: command-r | command-r-plus | command-r7b-12-2024
# ─────────────────────────────────────────────
COHERE_API_KEY=xxxxxx
COHERE_MODEL=command-r

# ─────────────────────────────────────────────
# EMBEDDINGS PROVIDER
# Pilih salah satu: voyage | openai | gemini | mistral | cohere | ollama
#
# Rekomendasi per LLM:
#   anthropic  → voyage  (gratis, partner resmi Anthropic)
#   openai     → openai  (1 key untuk segalanya)
#   gemini     → gemini  (1 key untuk segalanya)
#   mistral    → mistral (1 key untuk segalanya)
#   deepseek   → voyage  (DeepSeek tidak punya embeddings)
#   xai/grok   → voyage  (XAI tidak punya embeddings)
#   ollama     → ollama  (100% lokal, gratis)
#   cohere     → cohere  (1 key untuk segalanya)
# ─────────────────────────────────────────────
EMBEDDINGS_PROVIDER=voyage

# Voyage AI (https://dash.voyageai.com) — free tier 200jt token/bulan
# Model: voyage-3-lite | voyage-3 | voyage-3-large
VOYAGE_API_KEY=pa-xxxxxx
VOYAGE_EMBEDDING_MODEL=voyage-3-lite

# OpenAI Embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini Embeddings
# Model: text-embedding-004
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Mistral Embeddings
# Model: mistral-embed
MISTRAL_EMBEDDING_MODEL=mistral-embed

# Cohere Embeddings
# Model: embed-v4.0 | embed-multilingual-v3.0
COHERE_EMBEDDING_MODEL=embed-v4.0

# Ollama Embeddings (lokal)
# Model: nomic-embed-text | mxbai-embed-large (sesuai yang sudah di-pull)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─────────────────────────────────────────────
# VECTOR STORE
# ─────────────────────────────────────────────
VECTOR_STORE_DIR=./storage/vectors
VECTOR_STORE_NAME=knowledge_base

# ─────────────────────────────────────────────
# DATABASE MYSQL (untuk dashboard & settings)
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rag_chatbot
DB_USER=root
DB_PASS=

# ─────────────────────────────────────────────
# DASHBOARD AUTH
# ─────────────────────────────────────────────
# Secret key untuk enkripsi session (ganti dengan string random panjang)
APP_SECRET=ganti_dengan_random_string_panjang_ini

# ─────────────────────────────────────────────
# SMTP (cPanel)
# ─────────────────────────────────────────────
SMTP_HOST=mail.kemindogroup.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=chatbot@kemindogroup.com
SMTP_PASS=your_email_password
SMTP_FROM_NAME=Kemindo Chatbot
