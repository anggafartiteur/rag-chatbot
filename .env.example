# =============================================
# RAG Chatbot - Konfigurasi Environment
# =============================================

# Pilih LLM Provider: anthropic | openai
LLM_PROVIDER=anthropic

# OpenAI (untuk LLM + Embeddings - paling simpel, 1 API key saja)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (opsional, jika mau pakai Claude sebagai LLM)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_EMBEDDING_MODEL=voyage-3-lite

# Vector Store (FileVectorStore = gratis, lokal, cocok untuk demo)
VECTOR_STORE_DIR=./storage/vectors
VECTOR_STORE_NAME=knowledge_base
